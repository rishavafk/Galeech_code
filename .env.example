# ── Required ──────────────────────────────────────────────────────────────────
LEETCODE_USERNAME=your_leetcode_username

# Paste the full value of the "Cookie" header from your browser's DevTools.
# (Open leetcode.com → F12 → Network tab → any request → Headers → Cookie)
LEETCODE_COOKIE=csrftoken=abc123...; LEETCODE_SESSION=xyz...

# The csrftoken value alone (already inside the cookie above, also needed separately)
LEETCODE_CSRF=abc123...

# ── Optional ──────────────────────────────────────────────────────────────────
# How often to check (in minutes). Default: 30
POLL_INTERVAL_MINUTES=30

# Auto-resubmit only fires before this hour (24-h clock). Default: 12 (noon)
# After this hour the bot just warns but does NOT resubmit.
DEADLINE_HOUR=12
